# Server
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-random-secret

# Firebase Admin
# Option 1: serviceAccountKey.json in project root (local dev)
# Option 2: FIREBASE_SERVICE_ACCOUNT env var (production) — paste the full JSON
FIREBASE_PROJECT_ID=industrial-attachment-website
FIREBASE_WEB_API_KEY=your-web-api-key-here
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Gmail SMTP (password reset emails)
# Get an app password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
