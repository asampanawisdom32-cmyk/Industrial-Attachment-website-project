<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Bolgatanga Technical University Industrial Attachment Portal — streamline your internship journey with reports, evaluations, and progress tracking." />
  <meta name="author" content="Bolgatanga Technical University" />
  <meta name="theme-color" content="#2563EB" />
  <meta property="og:title" content="Industrial Attachment Portal — BTU" />
  <meta property="og:description" content="Streamline reports, evaluations, and internship progress for BTU students, supervisors, and administrators." />
  <meta property="og:type" content="website" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Industrial Attachment Portal — Bolgatanga Technical University</title>
  <script>if (localStorage.getItem('theme')==='dark') document.documentElement.setAttribute('data-theme','dark')</script>
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/home.css" />
</head>
<body class="home-page">
  <!-- Fullscreen Background -->
  <div class="home-bg-wrap">
    <div class="home-bg-img"></div>
    <div class="home-bg-overlay"></div>
  </div>

  <!-- Floating Particles -->
  <div class="home-particles">
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
    <div class="home-particle"></div>
  </div>

  <!-- Floating background orbs -->
  <div class="home-blob-3"></div>

  <!-- Navigation Bar -->
  <nav class="home-nav">
    <div class="home-nav-inner">
      <div class="home-nav-brand">
        <div class="home-nav-icon"><img src="/images/logo.png" alt="BTU Logo"></div>
        <div class="home-nav-text">
          <strong>Industrial Attachment</strong>
          <span>Bolgatanga Technical University</span>
        </div>
      </div>
      <div class="home-nav-links" id="home-nav-links">
        <a href="#features">Features</a>
        <a href="#about">About</a>
        <a href="/login" class="home-nav-btn">Sign In</a>
        <a href="/signup" class="home-nav-btn home-nav-btn-primary">Get Started</a>
      </div>
      <button class="home-nav-toggle" id="home-nav-toggle" aria-label="Toggle navigation">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="home-hero">
    <div class="home-hero-bg">
      <div class="home-hero-glow home-hero-glow-1"></div>
      <div class="home-hero-glow home-hero-glow-2"></div>
    </div>
    <div class="home-hero-content">
      <div class="home-hero-text">
        <span class="home-hero-badge">&#9733; Bolgatanga Technical University</span>
        <h1>Streamline Your<br/><em class="typewriter-text gradient-text" data-words='["Industrial Attachment","Internship Journey","Work Experience"]'>Industrial Attachment</em><span class="typing-cursor"></span> Journey</h1>
        <p>Submit weekly reports, receive real-time evaluations, track attendance, and monitor progress — all in one secure platform for students, supervisors, and administrators.</p>
        <div class="home-hero-actions">
          <a href="/signup" class="home-btn home-btn-primary">Get Started</a>
          <a href="/login" class="home-btn home-btn-outline">Sign In</a>
        </div>
      </div>
      <div class="home-hero-visual">
        <div class="home-hero-card">
          <div class="home-hero-card-header">
            <div class="home-hero-card-dot home-hero-card-dot-red"></div>
            <div class="home-hero-card-dot home-hero-card-dot-yellow"></div>
            <div class="home-hero-card-dot home-hero-card-dot-green"></div>
          </div>
          <div class="home-hero-card-body">
            <div class="home-hero-card-line home-hero-card-line-short"></div>
            <div class="home-hero-card-line home-hero-card-line-medium"></div>
            <div class="home-hero-card-line home-hero-card-line-long"></div>
            <div class="home-hero-card-line home-hero-card-line-medium"></div>
            <div class="home-hero-card-line home-hero-card-line-short"></div>
          </div>
          <div class="home-hero-card-footer">
            <span class="home-hero-card-status">&#9679; Report Reviewed</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="home-section reveal" id="features">
    <div class="home-section-label">Platform Features</div>
    <h2 class="home-section-title">Everything you need for a<br/>successful attachment program</h2>
    <p class="home-section-subtitle">Designed for students, supervisors, and administrators to collaborate seamlessly.</p>

    <div class="home-features stagger-children">
      <div class="home-feature-card card-3d">
        <div class="home-feature-icon home-feature-icon-blue">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3>Weekly Reports</h3>
        <p>Submit and review weekly industrial attachment reports with document attachments and supervisor feedback.</p>
      </div>

      <div class="home-feature-card card-3d">
        <div class="home-feature-icon home-feature-icon-gold">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3>Evaluations</h3>
        <p>Supervisors can rate and provide feedback on student performance with structured evaluation criteria.</p>
      </div>

      <div class="home-feature-card card-3d">
        <div class="home-feature-icon home-feature-icon-green">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3>Attendance Tracking</h3>
        <p>Mark and monitor daily attendance — present, absent, late, or excused — with progress indicators.</p>
      </div>

      <div class="home-feature-card card-3d">
        <div class="home-feature-icon home-feature-icon-purple">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <h3>Student Management</h3>
        <p>Administrators can manage student profiles, assign supervisors, and oversee the entire program.</p>
      </div>

      <div class="home-feature-card card-3d">
        <div class="home-feature-icon home-feature-icon-teal">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3>Analytics Dashboard</h3>
        <p>View program-wide statistics, department breakdowns, and placement insights at a glance.</p>
      </div>

      <div class="home-feature-card card-3d">
        <div class="home-feature-icon home-feature-icon-pink">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Secure &amp; Role-Based</h3>
        <p>Firebase authentication with role-based access for students, school supervisors, workplace supervisors, and admins.</p>
      </div>
    </div>
  </section>

  <!-- Stats Bar (auto-count) -->
  <section class="home-section reveal">
    <div class="home-section-label">Platform Impact</div>
    <h2 class="home-section-title">Trusted by the entire<br/>university community</h2>
    <div class="home-stats-bar">
      <div class="home-stat-item">
        <span class="home-stat-number" data-count-to="5000" data-count-suffix="+" data-count-duration="2500">0</span>
        <span class="home-stat-label">Students</span>
      </div>
      <div class="home-stat-item">
        <span class="home-stat-number" data-count-to="200" data-count-suffix="+" data-count-duration="2000">0</span>
        <span class="home-stat-label">Supervisors</span>
      </div>
      <div class="home-stat-item">
        <span class="home-stat-number" data-count-to="50" data-count-suffix="+" data-count-duration="1800">0</span>
        <span class="home-stat-label">Departments</span>
      </div>
      <div class="home-stat-item">
        <span class="home-stat-number" data-count-to="99" data-count-suffix="%" data-count-duration="2000">0</span>
        <span class="home-stat-label">Satisfaction</span>
      </div>
    </div>
  </section>

  <!-- About / How It Works -->
  <section class="home-section home-section-alt reveal" id="about">
    <div class="home-section-label">How It Works</div>
    <h2 class="home-section-title">A seamless workflow for<br/>every participant</h2>

    <div class="home-steps">
      <div class="home-step">
        <div class="home-step-number">1</div>
        <h3>Register &amp; Onboard</h3>
        <p>Create your account with your role — student, supervisor, or administrator. Complete your profile and get started.</p>
      </div>
      <div class="home-step-arrow">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
      <div class="home-step">
        <div class="home-step-number">2</div>
        <h3>Submit &amp; Evaluate</h3>
        <p>Students submit weekly reports with attachments. Supervisors review, rate, and provide feedback in real time.</p>
      </div>
      <div class="home-step-arrow">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </div>
      <div class="home-step">
        <div class="home-step-number">3</div>
        <h3>Track &amp; Complete</h3>
        <p>Monitor progress, attendance, and evaluations throughout the attachment period. Generate reports at completion.</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="home-cta reveal">
    <div class="home-cta-glow"></div>
    <div class="home-cta-content">
      <h2>Ready to streamline your<br/>attachment program?</h2>
      <p>Join students, supervisors, and administrators already using the platform.</p>
      <div class="home-cta-actions">
        <a href="/signup" class="home-btn home-btn-primary home-btn-lg home-btn-shimmer">Create Free Account</a>
        <a href="/login" class="home-btn home-btn-outline home-btn-lg">Sign In</a>
      </div>
    </div>
  </section>

  <!-- Premium Animations & Automation -->
  <script src="/js/home-animations.js"></script>

  <!-- Footer -->
  <footer class="home-footer">
    <div class="home-footer-inner">
      <div class="home-footer-brand">
        <div class="home-footer-logo"><img src="/images/logo.png" alt="BTU"></div>
        <div>
          <strong>Industrial Attachment Portal</strong>
          <span>Bolgatanga Technical University</span>
        </div>
      </div>
      <div class="home-footer-links">
        <a href="#features">Features</a>
        <a href="#about">How It Works</a>
        <a href="/login">Sign In</a>
        <a href="/signup">Register</a>
      </div>
      <p class="home-footer-copy">&copy; <%= new Date().getFullYear() %> Bolgatanga Technical University. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>