<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Bolgatanga Technical University Industrial Attachment Portal — Create an account to get started with internship tracking." />
  <meta name="author" content="Bolgatanga Technical University" />
  <meta name="theme-color" content="#2563EB" />
  <meta property="og:title" content="Create Account | Industrial Attachment Portal" />
  <meta property="og:description" content="Register as a student, supervisor, or administrator to manage industrial attachment workflows at BTU." />
  <meta property="og:type" content="website" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Create Account | Industrial Attachment Portal</title>
  <!-- Restore dark mode before paint -->
  <script>if (localStorage.getItem('theme')==='dark') document.documentElement.setAttribute('data-theme','dark')</script>
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="login-page">
  <!-- Fullscreen Background -->
  <div class="auth-bg-wrap">
    <div class="auth-bg-img"></div>
    <div class="auth-bg-overlay"></div>
  </div>

  <!-- Floating Particles -->
  <div class="auth-particles">
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
  </div>

  <!-- Animated background blobs -->
  <div class="login-blob-3"></div>

  <div class="login-wrapper auth-3d">
    <div class="login-wrapper-inner">
    <!-- Left: Brand Panel (same as login) -->
    <div class="login-brand-panel">
      <div class="brand-logo-wrap">
        <div class="brand-icon"><img src="/images/logo.png" alt="BTU Logo"></div>
        <div class="brand-text">
          <h2>Bolgatanga Technical University</h2>
          <span>Industrial Attachment Portal</span>
        </div>
      </div>

      <h1>Streamline your<br/><em class="auth-gradient-text auth-typewriter-text" data-words='["internship journey","attachment tracking","career growth"]'>internship journey</em><span class="auth-typing-cursor"></span></h1>
      <p>Track reports, evaluations, and progress — all in one secure platform for students, supervisors, and administrators.</p>

      <div class="login-features auth-reveal">
        <div class="login-feature">
          <div class="login-feature-icon">&#10003;</div>
          <span>Submit and review weekly attachment reports</span>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon">&#10003;</div>
          <span>Real-time evaluations and supervisor feedback</span>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon">&#10003;</div>
          <span>Track attendance and placement progress</span>
        </div>
      </div>
    </div>

    <!-- Right: Form Panel -->
    <div class="login-form-panel">
      <h2>Create your account</h2>
      <p class="form-subtitle">Fill in the details below to get started.</p>

      <div id="auth-message" class="auth-message" hidden></div>

      <form id="signup-form" method="post" novalidate>
        <!-- Role -->
        <div class="premium-input-group">
          <label for="signup-role">Role</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </span>
            <select id="signup-role" name="signup-role">
              <option>Student</option>
              <option>Admin</option>
              <option>School Supervisor</option>
              <option>Workplace Supervisor</option>
            </select>
          </div>
        </div>

        <!-- Full Name -->
        <div class="premium-input-group">
          <label for="signup-name">Full name</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </span>
            <input id="signup-name" name="signup-name" type="text" placeholder="Enter your full name" required autocomplete="name" />
          </div>
        </div>

        <!-- Student extra fields -->
        <div id="student-extra" style="display:none">
          <div class="premium-input-group">
            <label for="signup-index">Index number</label>
            <div class="premium-input-wrap">
              <span class="input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <line x1="3" y1="9" x2="21" y2="9"/>
                  <line x1="9" y1="21" x2="9" y2="9"/>
                </svg>
              </span>
              <input id="signup-index" name="signup-index" type="text" placeholder="e.g. BTU-2025-001" />
            </div>
          </div>
          <div class="premium-input-group">
            <label for="signup-department">Department</label>
            <div class="premium-input-wrap">
              <span class="input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
              </span>
              <input id="signup-department" name="signup-department" type="text" placeholder="e.g. Computer Science" />
            </div>
          </div>
          <div class="premium-input-group">
            <label for="signup-phone">Phone number</label>
            <div class="premium-input-wrap">
              <span class="input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
              </span>
              <input id="signup-phone" name="signup-phone" type="tel" placeholder="e.g. +233 50 123 4567" />
            </div>
          </div>
          <div class="premium-input-group">
            <label for="signup-company">Company name</label>
            <div class="premium-input-wrap">
              <span class="input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                  <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
              </span>
              <input id="signup-company" name="signup-company" type="text" placeholder="Enter company name (if applicable)" />
            </div>
          </div>
          <div class="premium-input-group">
            <label for="signup-location">Location</label>
            <div class="premium-input-wrap">
              <span class="input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              <input id="signup-location" name="signup-location" type="text" placeholder="Enter your location" />
            </div>
          </div>
        </div>

        <!-- Email -->
        <div class="premium-input-group">
          <label for="signup-email">Email</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <input id="signup-email" name="signup-email" type="email" placeholder="you@domain.edu" required autocomplete="email" />
          </div>
        </div>

        <!-- Password -->
        <div class="premium-input-group">
          <label for="signup-password">Password</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input id="signup-password" name="signup-password" type="password" placeholder="Create a password (min. 6 characters)" required autocomplete="new-password" minlength="6" />
            <button type="button" class="input-toggle-pw" id="signup-toggle-pw" aria-label="Toggle password visibility" tabindex="-1">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Password Strength Meter -->
        <div class="pw-strength-wrap" id="pw-strength-wrap" hidden>
          <div class="pw-strength-bar">
            <div class="pw-strength-segment" id="pw-seg-1"></div>
            <div class="pw-strength-segment" id="pw-seg-2"></div>
            <div class="pw-strength-segment" id="pw-seg-3"></div>
          </div>
          <span class="pw-strength-label" id="pw-strength-label"></span>
        </div>

        <button type="submit" class="btn-login" id="signup-submit">
          <span class="spinner-btn"></span>
          <span class="btn-text">Create Account</span>
        </button>
      </form>

      <div class="login-form-footer">
        <a href="/" class="forgot-back-link" style="margin-bottom:8px;display:inline-flex">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to Home
        </a>
        <div>Already have an account? <a href="/login">Sign in</a></div>
      </div>
    </div>
    </div>
  </div>

  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/auth-animations.js"></script>
  <script>
    (function () {
      // --- Student extra fields toggle ---
      var roleSelect = document.getElementById('signup-role');
      var studentExtra = document.getElementById('student-extra');

      function toggleStudentExtra() {
        if (!roleSelect || !studentExtra) return;
        studentExtra.style.display = roleSelect.value === 'Student' ? 'block' : 'none';
      }

      if (roleSelect) {
        roleSelect.addEventListener('change', toggleStudentExtra);
        toggleStudentExtra();
      }

      // --- Admin option removal if admin already exists ---
      fetch('/api/auth/admin-exists')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.exists && roleSelect) {
            var adminOption = roleSelect.querySelector('option[value="Admin"]');
            if (adminOption) adminOption.remove();
            if (roleSelect.value === 'Admin') {
              roleSelect.value = 'Student';
              toggleStudentExtra();
            }
          }
        })
        .catch(function () { /* ignore */ });

      // --- Password toggle for signup ---
      var toggleBtn = document.getElementById('signup-toggle-pw');
      var pwInput = document.getElementById('signup-password');
      if (toggleBtn && pwInput) {
        toggleBtn.addEventListener('click', function () {
          var isPassword = pwInput.type === 'password';
          pwInput.type = isPassword ? 'text' : 'password';
          toggleBtn.innerHTML = isPassword
            ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>'
            : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
        });
      }

      // --- If already authenticated, redirect ---
      if (window.IaApi && window.IaApi.getToken()) {
        window.IaApi.apiFetch('/api/auth/profile')
          .then(function () {
            window.location.href = '/dashboard';
          })
          .catch(function () {
            window.IaApi.clearSession();
          });
      }
    })();
  </script>
</body>
</html>
