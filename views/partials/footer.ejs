      </section>
    </main>
  </div>

  <!-- Core scripts -->
  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/notifications.js"></script>
  <script src="/js/app-pages.js"></script>

  <!-- Admin premium animations (admin pages only) -->
  <script>
    (function() {
      var page = document.body && document.body.dataset.page;
      if (['admin-dashboard', 'admin', 'students', 'reports', 'evaluations', 'analytics', 'profile', 'supervisors'].indexOf(page) !== -1) {
        var s = document.createElement('script');
        s.src = '/js/admin-animations.js';
        document.body.appendChild(s);
      }
    })();
  </script>

  <!-- Role-specific scripts loaded on-demand via data-page attribute -->
  <script>
    (function() {
      var page = document.body && document.body.dataset.page;
      var scripts = {
        'admin': '/js/admin.js',
        'admin-dashboard': '/js/dashboards/admin-dashboard.js',
        'student-dashboard': '/js/dashboards/student-dashboard.js',
        'school-supervisor-dashboard': '/js/dashboards/supervisor-dashboard.js',
        'workplace-supervisor-dashboard': '/js/dashboards/supervisor-dashboard.js',
        'supervisors': '/js/supervisors.js',
      };
      var src = scripts[page];
      if (src) {
        var s = document.createElement('script');
        s.src = src;
        document.body.appendChild(s);
      }
    })();
  </script>

  <!-- Mobile optimizations -->
  <script>
    (function() {
      /* Table scroll hint on mobile */
      function initTableScrollHints() {
        document.querySelectorAll('.table-premium-wrap').forEach(function(wrap) {
          function checkScroll() {
            if (wrap.scrollWidth > wrap.clientWidth) {
              wrap.classList.add('scrollable');
            } else {
              wrap.classList.remove('scrollable');
            }
          }
          checkScroll();
          wrap.addEventListener('scroll', checkScroll);
          window.addEventListener('resize', checkScroll);
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTableScrollHints);
      } else {
        initTableScrollHints();
      }
      /* Re-run after dynamic content loads */
      setTimeout(initTableScrollHints, 1500);
      setTimeout(initTableScrollHints, 3000);

      /* Close sidebar on nav click (mobile) */
      document.querySelectorAll('.nav-item').forEach(function(item) {
        item.addEventListener('click', function() {
          var sidebar = document.querySelector('[data-sidebar]');
          var overlay = document.querySelector('[data-sidebar-overlay]');
          if (sidebar) sidebar.classList.remove('open');
          if (overlay) overlay.classList.remove('active');
        });
      });
    })();
  </script>
</body>
</html>