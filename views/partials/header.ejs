<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Bolgatanga Technical University Industrial Attachment Portal — Manage reports, evaluations, and internship progress." />
  <meta name="author" content="Bolgatanga Technical University" />
  <meta name="theme-color" content="#2563EB" />
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Industrial Attachment Portal' %>" />
  <meta property="og:description" content="Secure platform for BTU students, supervisors, and administrators to track industrial attachment workflows." />
  <meta property="og:type" content="website" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title><%= typeof title !== 'undefined' ? title : 'Industrial Attachment Portal' %></title>
  
  <!-- Restore dark mode before paint to prevent flash -->
  <script>if (localStorage.getItem('theme') === 'dark') document.documentElement.setAttribute('data-theme','dark')</script>
  
  <!-- Fonts are imported via layout.css -->
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/dashboard.css">

  <!-- admin.css is used by all dashboard templates (admin, student, supervisor) for admin-stats-grid / admin-stat-card classes -->
  <% if (typeof page !== 'undefined' && page !== '' && page !== 'login' && page !== 'signup' && page !== 'error') { %>
    <link rel="stylesheet" href="/css/admin.css">
  <% } %>

  <!-- Admin premium background & animations (admin pages only) -->
  <% if (typeof page !== 'undefined' && ['admin-dashboard', 'admin', 'students', 'reports', 'evaluations', 'analytics', 'profile', 'supervisors'].includes(page)) { %>
    <link rel="stylesheet" href="/css/admin-bg.css">
  <% } %>

  <style>
    /* Ensure sidebar profile is shown (populated by auth-guard.js) */
    #sidebar-profile-name, #sidebar-profile-role { transition: opacity 0.3s ease; }
    /* Premium page transition */
    .page-content { animation: pageEnter 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
    .page-content.is-exiting { animation: pageExit 0.2s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
    @keyframes pageEnter { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes pageExit { to { opacity: 0; transform: translateY(-8px); } }
  </style>
</head>
<body data-page="<%= typeof page !== 'undefined' ? page : '' %>">
  <!-- Admin campus background + particles (admin pages only) -->
  <% if (typeof page !== 'undefined' && ['admin-dashboard', 'admin', 'students', 'reports', 'evaluations', 'analytics', 'profile', 'supervisors'].includes(page)) { %>
    <div class="admin-bg-wrap">
      <div class="admin-bg-img"></div>
      <div class="admin-bg-overlay"></div>
    </div>
    <div class="admin-particles">
      <% for (var i = 1; i <= 12; i++) { %><div class="admin-particle"></div><% } %>
    </div>
  <% } %>
  <div class="app-shell">

    <!-- ============================================================
         Sidebar
         ============================================================ -->
    <aside class="sidebar" data-sidebar>
      <!-- Brand -->
      <div class="sidebar-brand">
        <div class="sidebar-brand-icon"><img src="/images/logo.png" alt="BTU"></div>
        <div class="sidebar-brand-text">
          <span class="sidebar-brand-title">Industrial Attachment</span>
          <span class="sidebar-brand-subtitle">Bolgatanga Technical University</span>
        </div>
      </div>

      <!-- User Profile (compact in sidebar) — populated by auth-guard.js -->
      <div class="sidebar-profile" id="sidebar-profile">
        <div class="sidebar-profile-avatar" id="sidebar-profile-avatar">
          <span class="sidebar-profile-initials" id="sidebar-profile-initials">U</span>
          <span class="status-dot"></span>
        </div>
        <div class="sidebar-profile-info">
          <span class="sidebar-profile-name" id="sidebar-profile-name">Dashboard</span>
          <span class="sidebar-profile-role" id="sidebar-profile-role">Loading...</span>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="nav-menu">
        <div class="nav-section-label">Main</div>

        <a href="/dashboard/student" class="nav-item" data-page="student-dashboard" data-role="student" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          <span class="nav-label">Dashboard</span>
        </a>

        <a href="/dashboard/admin" class="nav-item" data-page="admin-dashboard" data-role="admin" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="nav-label">Dashboard</span>
        </a>

        <a href="/dashboard/school-supervisor" class="nav-item" data-page="school-supervisor-dashboard" data-role="school_supervisor" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          <span class="nav-label">Dashboard</span>
        </a>

        <a href="/dashboard/workplace-supervisor" class="nav-item" data-page="workplace-supervisor-dashboard" data-role="workplace_supervisor" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          <span class="nav-label">Dashboard</span>
        </a>

        <a href="/analytics" class="nav-item" data-page="analytics" data-role="admin" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
          <span class="nav-label">Analytics</span>
        </a>

        <a href="/admin" class="nav-item" data-page="admin" data-role="admin" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="nav-label">Admin Panel</span>
        </a>

        <a href="/supervisors" class="nav-item" data-page="supervisors" data-role="admin" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="nav-label">Supervisors</span>
        </a>

        <div class="nav-section-label" style="padding-top:16px;">Sections</div>

        <a href="/students" class="nav-item" data-page="students" data-role="admin school_supervisor workplace_supervisor" hidden>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          <span class="nav-label">Students</span>
        </a>

        <a href="/reports" class="nav-item" data-page="reports">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          <span class="nav-label">Reports</span>
        </a>

        <a href="/evaluations" class="nav-item" data-page="evaluations">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span class="nav-label">Evaluations</span>
        </a>

        <a href="/profile" class="nav-item" data-page="profile">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="nav-label">Profile</span>
        </a>
      </nav>

      <!-- Theme Toggle -->
      <div class="nav-item theme-toggle" id="theme-toggle" title="Toggle dark mode">
        <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <span class="nav-label">Dark Mode</span>
      </div>

      <!-- Sidebar Footer (Logout) - populated by JS -->
      <div class="sidebar-footer"></div>
    </aside>

    <!-- Mobile sidebar overlay -->
    <div class="sidebar-overlay" data-sidebar-overlay></div>

    <!-- ============================================================
         Main Panel
         ============================================================ -->
    <main class="main-panel">
      <!-- Page Header -->
      <header class="page-header">
        <div class="page-header-left">
          <button class="sidebar-toggle-btn" id="sidebar-toggle" aria-label="Toggle sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <div class="page-header-title-group">
            <h1><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
          </div>
        </div>

        <div class="page-header-actions">
          <button class="notification-btn" aria-label="Notifications">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span class="notification-dot"></span>
          </button>
        </div>
      </header>

      <!-- Page Content — content is injected by page-specific JS -->
      <section class="page-content" data-page-content>
