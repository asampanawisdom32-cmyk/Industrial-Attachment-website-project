<%- include('../partials/header', { title: 'Admin Dashboard', page: 'admin-dashboard' }) %>

<div id="dashboard-root" data-role="admin" data-page-root>

  <!-- Admin Stats Grid -->
  <div class="admin-stats-grid" id="admin-stats">
    <div class="admin-stat-card primary">
      <div class="admin-stat-value" id="admin-total-students">—</div>
      <div class="admin-stat-label">Total Students</div>
    </div>
    <div class="admin-stat-card teal">
      <div class="admin-stat-value" id="admin-active-students">—</div>
      <div class="admin-stat-label">Active</div>
    </div>
    <div class="admin-stat-card gold">
      <div class="admin-stat-value" id="admin-pending-reports">—</div>
      <div class="admin-stat-label">Pending Reports</div>
    </div>
    <div class="admin-stat-card blue">
      <div class="admin-stat-value" id="admin-supervisors">—</div>
      <div class="admin-stat-label">Supervisors</div>
    </div>
  </div>

  <!-- Analytics Grid -->
  <div class="analytics-grid">
    <div class="premium-card">
      <div class="premium-card-header">
        <h3>Recent Registrations</h3>
        <a href="/students" class="section-link">Manage →</a>
      </div>
      <div class="premium-card-body">
        <div class="activity-list" id="admin-activity-list">
          <div class="activity-item">
            <div class="activity-dot primary"></div>
            <div class="activity-content">
              <div class="activity-text">Admin dashboard ready — user activity will appear here.</div>
              <div class="activity-time">Just now</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="premium-card">
      <div class="premium-card-header">
        <h3>System Overview</h3>
      </div>
      <div class="premium-card-body">
        <div class="circular-progress-grid" id="admin-progress-grid">
          <!-- Populated by JS with 3 progress rings -->
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="dashboard-section">
    <div class="dashboard-section-header">
      <h2>Administration</h2>
    </div>
    <div class="quick-actions">
      <button class="quick-action-btn" onclick="window.location.href='/students'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        Manage Students
      </button>
      <button class="quick-action-btn" onclick="window.location.href='/admin'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Admin Panel
      </button>
      <button class="quick-action-btn" onclick="window.location.href='/analytics'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        View Analytics
      </button>
      <button class="quick-action-btn" onclick="window.location.href='/reports'">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        All Reports
      </button>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
