<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#2563EB" />
  <title><%= typeof status !== 'undefined' && status === 404 ? 'Page Not Found' : 'Error' %> | IA Link</title>
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <script>if (localStorage.getItem('theme')==='dark') document.documentElement.setAttribute('data-theme','dark')</script>
</head>
<body class="login-page">
  <!-- Animated background blobs -->
  <div class="login-blob-3"></div>

  <div class="error-wrapper">
    <!-- Error Card -->
    <div class="error-card">
      <!-- Decorative circle behind error code -->
      <div class="error-decoration">
        <svg width="200" height="200" viewBox="0 0 200 200" fill="none">
          <circle cx="100" cy="100" r="95" stroke="currentColor" stroke-width="0.5" opacity="0.08" />
          <circle cx="100" cy="100" r="70" stroke="currentColor" stroke-width="0.5" opacity="0.06" />
          <circle cx="100" cy="100" r="45" stroke="currentColor" stroke-width="0.5" opacity="0.04" />
        </svg>
      </div>

      <!-- Error Code -->
      <div class="error-code"><%= typeof status !== 'undefined' ? status : '500' %></div>

      <!-- Error Icon -->
      <div class="error-icon-wrap">
        <% if (typeof status !== 'undefined' && status === 404) { %>
          <!-- 404: compass/explorer icon -->
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
          </svg>
        <% } else { %>
          <!-- 500: alert triangle icon -->
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        <% } %>
      </div>

      <!-- Message -->
      <h1 class="error-title">
        <% if (typeof status !== 'undefined' && status === 404) { %>
          Page Not Found
        <% } else { %>
          Something Went Wrong
        <% } %>
      </h1>
      <p class="error-message"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>

      <!-- Helpful Suggestions -->
      <div class="error-suggestions">
        <div class="error-suggestion">
          <span class="error-suggestion-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </span>
          <span>Try checking the URL for typos</span>
        </div>
        <div class="error-suggestion">
          <span class="error-suggestion-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </span>
          <span>If the problem persists, contact support</span>
        </div>
      </div>

      <!-- Actions -->
      <div class="error-actions">
        <a href="/" class="btn-error-primary" id="error-home-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          Go Home
        </a>
        <a href="/login" class="btn-error-secondary" id="error-login-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Sign In
        </a>
      </div>
    </div>
  </div>

  <script src="/js/api.js"></script>
  <script>
    (function () {
      // If user is authenticated, redirect the login button to dashboard
      var loginBtn = document.getElementById('error-login-btn');
      if (loginBtn && window.IaApi && window.IaApi.getToken()) {
        loginBtn.href = '/dashboard';
        loginBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg> Dashboard';
        loginBtn.classList.remove('btn-error-secondary');
        loginBtn.classList.add('btn-error-primary');
      }
    })();
  </script>
</body>
</html>
