<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Bolgatanga Technical University Industrial Attachment Portal — Sign in to track reports, evaluations, and internship progress." />
  <meta name="author" content="Bolgatanga Technical University" />
  <meta name="theme-color" content="#2563EB" />
  <meta property="og:title" content="Sign In | Industrial Attachment Portal" />
  <meta property="og:description" content="Secure sign-in for BTU students, supervisors, and administrators to manage industrial attachment workflows." />
  <meta property="og:type" content="website" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Sign In | Industrial Attachment Portal</title>
  <!-- Restore dark mode before paint -->
  <script>if (localStorage.getItem('theme')==='dark') document.documentElement.setAttribute('data-theme','dark')</script>
  <link rel="stylesheet" href="/css/layout.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="login-page">
  <!-- Fullscreen Background -->
  <div class="auth-bg-wrap">
    <div class="auth-bg-img"></div>
    <div class="auth-bg-overlay"></div>
  </div>

  <!-- Floating Particles -->
  <div class="auth-particles">
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
    <div class="auth-particle"></div>
  </div>

  <!-- Animated background blobs -->
  <div class="login-blob-3"></div>

  <div class="login-wrapper auth-3d">
    <div class="login-wrapper-inner">
    <!-- Left: Brand Panel -->
    <div class="login-brand-panel">
      <div class="brand-logo-wrap">
        <div class="brand-icon"><img src="/images/logo.png" alt="BTU Logo"></div>
        <div class="brand-text">
          <h2>Bolgatanga Technical University</h2>
          <span>Industrial Attachment Portal</span>
        </div>
      </div>

      <h1>Streamline your<br/><em class="auth-gradient-text auth-typewriter-text" data-words='["internship journey","attachment tracking","career growth"]'>internship journey</em><span class="auth-typing-cursor"></span></h1>
      <p>Track reports, evaluations, and progress — all in one secure platform for students, supervisors, and administrators.</p>

      <div class="login-features auth-reveal">
        <div class="login-feature">
          <div class="login-feature-icon">&#10003;</div>
          <span>Submit and review weekly attachment reports</span>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon">&#10003;</div>
          <span>Real-time evaluations and supervisor feedback</span>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon">&#10003;</div>
          <span>Track attendance and placement progress</span>
        </div>
      </div>
    </div>

    <!-- Right: Form Panel -->
    <div class="login-form-panel">
      <h2>Welcome back</h2>
      <p class="form-subtitle">Sign in to your account to continue.</p>

      <div id="auth-message" class="auth-message" hidden></div>

      <form id="login-form" method="post" novalidate>
        <div class="premium-input-group">
          <label for="login-role">Role</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </span>
            <select id="login-role" name="login-role">
              <option>Student</option>
              <option>Admin</option>
              <option>School Supervisor</option>
              <option>Workplace Supervisor</option>
            </select>
          </div>
        </div>

        <div class="premium-input-group">
          <label for="login-email">Email</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <input id="login-email" type="email" name="email" placeholder="you@domain.edu" required autocomplete="email" />
          </div>
        </div>

        <div class="premium-input-group">
          <label for="login-password">Password</label>
          <div class="premium-input-wrap">
            <span class="input-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input id="login-password" type="password" name="password" placeholder="Enter your password" required autocomplete="current-password" />
            <button type="button" class="input-toggle-pw" id="toggle-pw" aria-label="Toggle password visibility" tabindex="-1">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="login-options">
          <label class="remember-me">
            <input type="checkbox" id="remember-me" /> Remember me
          </label>
          <a href="#" class="forgot-link" id="forgot-link">Forgot password?</a>
        </div>

        <button type="submit" class="btn-login" id="login-submit">
          <span class="spinner-btn"></span>
          <span class="btn-text">Sign In</span>
        </button>
      </form>

      <div class="login-form-footer">
        <a href="/" class="forgot-back-link" style="margin-bottom:8px;display:inline-flex">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back to Home
        </a>
        <div>Don't have an account? <a href="/signup">Create one</a></div>
      </div>
    </div>
    </div>
  </div>

  <!-- Forgot Password Modal -->
  <div class="modal-overlay" id="forgot-modal" hidden>
    <div class="modal-card forgot-modal-card">
      <div class="modal-header">
        <h3>Reset password</h3>
        <button type="button" class="modal-close" id="forgot-close" aria-label="Close">&times;</button>
      </div>
      <div class="modal-body forgot-modal-body">
        <!-- Default state: email input -->
        <div id="forgot-default">
          <div class="forgot-icon-wrap">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <p class="forgot-subtitle">Enter your registered email address and we'll send you a link to reset your password.</p>
          <div class="premium-input-group">
            <label for="forgot-email">Email</label>
            <div class="premium-input-wrap">
              <span class="input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <input id="forgot-email" type="email" placeholder="you@domain.edu" required autocomplete="email" />
            </div>
          </div>
          <div id="forgot-error" class="auth-message auth-message-error" hidden></div>
          <button type="button" class="btn-login" id="forgot-submit">
            <span class="spinner-btn"></span>
            <span class="btn-text">Send Reset Link</span>
          </button>
        </div>
        <!-- Success state -->
        <div id="forgot-success" hidden>
          <div class="forgot-icon-wrap forgot-icon-success">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <p class="forgot-success-title">Check your inbox</p>
          <p class="forgot-success-text">If an account exists for <strong id="forgot-sent-email"></strong>, you'll receive a password reset link shortly.</p>
          <p class="forgot-success-hint">Didn't receive the email? Check your spam folder or <a href="#" id="forgot-resend">try again</a>.</p>
        </div>
      </div>
      <div class="modal-footer forgot-modal-footer">
        <a href="#" id="forgot-back" class="forgot-back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          Back to Sign In
        </a>
      </div>
    </div>
  </div>

  <script src="/js/api.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/auth-animations.js"></script>
</body>
</html>
