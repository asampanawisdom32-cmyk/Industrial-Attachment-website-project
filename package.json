{
  "name": "industrial-attachment-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "cd client && npm install --include=dev && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "node app.js",
    "start:cluster": "node cluster.js",
    "start:prod": "npx pm2 start app.js -i max",
