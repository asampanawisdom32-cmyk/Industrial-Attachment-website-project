    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "helmet": "^7.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "jest": "^30.4.2",
    "markdownlint-cli": "^0.48.0",
    "pm2": "^7.0.3"
  }
}
